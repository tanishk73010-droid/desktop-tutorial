class Animal {
    String name;

    void eat() {
        System.out.println(name + " is eating.");
    }

protected void runs()
{
    System.out.println("Animal is Running");
}
}

class Dog extends Animal {
    void bark() {
        System.out.println(name + " says: Woof!");
        runs();
    }
    
}

public class Main {
    public static void main(String[] args) {
        Dog myDog = new Dog();
        myDog.name = "Buddy";
        
        myDog.eat(); 
        myDog.bark();
    }
}
